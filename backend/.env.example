# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/placement-buddy?retryWrites=true&w=majority
COLLEGE_EMAIL_DOMAIN=college.edu

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# Cloudinary (Optional, required for resume uploads)
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ──────────────────────────────────────────────
# OpenWA Gateway
# ──────────────────────────────────────────────
OPENWA_API_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=placement-buddy
WHATSAPP_GROUP_ID=

