# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/placement-buddy?retryWrites=true&w=majority
COLLEGE_EMAIL_DOMAIN=college.edu

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug
